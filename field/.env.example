# CommonUnity Field — environment variables
# Copy to .env (in development) or set in Railway dashboard (in production).

# Bind port (Railway sets this automatically)
PORT=5050

# Where to put the SQLite DB file. Default: ./data.db
# In Railway, attach a volume and set DATABASE_URL=/data/data.db
DATABASE_URL=./data.db

# Magic-link auth — issuer base URL (used to build the link emailed to users)
FIELD_BASE_URL=http://localhost:5050

# Session secret. Change in production.
SESSION_SECRET=change-me-in-production

# Beta seed users (semicolon-separated email addresses). Anyone with these
# emails is auto-created on first magic-link request without an invite.
# These are the three real Phase 1 beta seats — all profiles seeded from JSON:
#   Markus Lehto    markuslehto@mac.com    (handle pinned to markus-lehto)
#   Vesna Lucca     vesna.lucca@gmail.com
#   Eda Çarmıklı    eda@jointidea.com      (handle pinned to eda-carmikli)
BETA_USERS=markuslehto@mac.com;vesna.lucca@gmail.com;eda@jointidea.com

# Optional per-person overrides — the seed importer will use these when
# publishing each profile, otherwise it falls back to the values above.
VESNA_EMAIL=vesna.lucca@gmail.com
EDA_EMAIL=eda@jointidea.com
MARKUS_EMAIL=markuslehto@mac.com

# Optional SMTP for magic-link emails. Leave blank to print links to the console
# (dev fallback). All four must be set to enable email sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CommonUnity Field <noreply@commonunity.io>"

# CORS allow-list for Studio "Publish to Field" requests. Comma-separated.
ALLOWED_ORIGINS=http://localhost:8000,https://commonunity-production.up.railway.app

# Opt-in to require beta auth even to read the gallery. Default: 0 (public read).
EARLY_BETA=0
